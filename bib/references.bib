@article{WANG2018121,
  author   = {Chen Wang and Huaqiang Wu and Bin Gao and Teng Zhang and Yuchao Yang and He Qian},
  journal  = {Microelectronic Engineering},
  title    = {Conduction mechanisms, dynamics and stability in ReRAMs},
  year     = {2018},
  issn     = {0167-9317},
  pages    = {121-133},
  volume   = {187-188},
  abstract = {Though resistive random access memory (ReRAM), a promising emerging memory technology, has achieved remarkable progress in technology development in recent years, our understanding of its conduction mechanisms, dynamic processes and stability issues is still limited. Because of this, this paper reviews recent research on the understanding of carrier transport, dynamics of conductive filament (CF) and failure mechanisms of stability issues. Critical challenges are summarized to clarify various intrinsic and non-intrinsic characteristics of ReRAM. The details of ion transport and redox dynamics of resistive switching are reviewed. Failure mechanisms of stability issues are discussed, including the tail bits degradation (relaxation effect). Random Telegraph Noise (RTN) studies are also reviewed as a reflection of oxygen vacancy movements to understand other stability issues.},
  comment  = {Overview of ReRAM conduction mechanisms. Latter sections focus on reliability, variance, and stability. Good explanation of failure modes (stuck at HRS, stuck at LRS, stuck at intermediate state) as well as the physics of random variations (RTN in LRS and HRS). Like papers above, no link to RTN and prior read/write patterns but it is plausible that the physics described that drives RTN can be linked to prior patterns.},
  doi      = {https://doi.org/10.1016/j.mee.2017.11.003},
  keywords = {ReRAM, Conduction mechanisms, Dynamics, Stability},
  url      = {https://www.sciencedirect.com/science/article/pii/S0167931717303672}
}

@incollection{BERSUKER201935,
  author    = {G. Bersuker and D.C. Gilmer and D. Veksler},
  booktitle = {Advances in Non-Volatile Memory and Storage Technology (Second Edition)},
  publisher = {Woodhead Publishing},
  title     = {2 - Metal-oxide resistive random access memory (RRAM) technology: Material and operation details and ramifications},
  year      = {2019},
  edition   = {Second Edition},
  editor    = {Blanka Magyari-Köpe and Yoshio Nishi},
  isbn      = {978-0-08-102584-0},
  pages     = {35-102},
  series    = {Woodhead Publishing Series in Electronic and Optical Materials},
  abstract  = {Detailed operational and intrinsic switching characteristics for hafnia-based resistive random access memory (RRAM) are presented, including materials/vacancy engineering ramifications. The entire set of reported experimental data and material structure modeling and transport simulation results are consistent with the physical picture of the RRAM operations as caused by oxidation/reduction processes in a conducting filament formed in the dielectric. The outcome of the filament formation process establishes initial structural conditions for the subsequent switching operations. A microscopic description of these processes, the framework of which is presented here, directly links the device electrical and material characteristics, thus enabling improving device performance through optimization of the material compositional profile and operation conditions.},
  comment   = {Overview of ReRAM conduction mechanisms. Latter sections focus on reliability, variance, and stability. Good explanation of failure modes (stuck at HRS, stuck at LRS, stuck at intermediate state) as well as the physics of random variations (RTN in LRS and HRS). Like papers above, no link to RTN and prior read/write patterns but it is plausible that the physics described that drives RTN can be linked to prior patterns.},
  doi       = {https://doi.org/10.1016/B978-0-08-102584-0.00002-4},
  keywords  = {Resistive random access memory (RRAM), ReRAM, Memristor, Nonvolatile memories, HfO, Hafnia, Resistance change, Dielectric breakdown, Conductive filament, Neuromorphic computing},
  url       = {https://www.sciencedirect.com/science/article/pii/B9780081025840000024}
}

