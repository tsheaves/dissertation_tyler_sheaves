@article{compton2002rcs,
  abstract     = {Due to its potential to greatly accelerate a wide variety of applications, reconfigurable computing has become a subject of a great deal of research. Its key feature is the ability to perform computations in hardware to increase performance, while retaining much of the flexibility of a software solution. In this survey, we explore the hardware aspects of reconfigurable computing machines, from single chip architectures to multi-chip systems, including internal structures and external coupling. We also focus on the software that targets these machines, such as compilation tools that map high-level algorithms directly to the reconfigurable substrate. Finally, we consider the issues involved in run-time reconfigurable systems, which reuse the configurable hardware during program execution.},
  author       = {Compton, Katherine and Hauck, Scott},
  location     = {New York, NY, USA},
  publisher    = {Association for Computing Machinery},
  url          = {https://doi.org/10.1145/508352.508353},
  date         = {2002-06},
  doi          = {10.1145/508352.508353},
  issn         = {0360-0300},
  journaltitle = {ACM Comput. Surv.},
  keywords     = {FPGA,reconfigurable architectures,Automatic design,manual design,reconfigurable systems,reconfigurable computing,field-programmable},
  number       = {2},
  pages        = {171--210},
  title        = {Reconfigurable Computing: A Survey of Systems and Software},
  volume       = {34}
}

@article{nunes2013ffbti,
  abstract     = {This work presents a comparative analysis of aging impact in CMOS flip–flops. Five different static flip–flop topologies have been evaluated based on an aging estimation method previously proposed for combinational circuits. BTI, HCI and TDDB are taken into account in such investigation, considering the individual and combined influences. The operation degradation of each transistor present in the flip–flop circuit is provided by the applied methodology. Moreover, electrical simulations were carried out in order to compare all five flip–flops evaluated in terms of propagation delay increasing. This work demonstrates that the impact of wearout mechanisms might be considered as an important design parameter in the choice of the most appropriate flip–flop in specific applications.},
  author       = {Nunes, Cícero and Butzen, Paulo F. and Reis, André I. and Ribas, Renato P.},
  url          = {https://www.sciencedirect.com/science/article/pii/S0026271413002199},
  date         = {2013},
  doi          = {https://doi.org/10.1016/j.microrel.2013.07.044},
