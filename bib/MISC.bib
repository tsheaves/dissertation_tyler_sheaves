@Article{HUARD20061,
  author   = {V. Huard and M. Denais and C. Parthasarathy},
  journal  = {Microelectronics Reliability},
  title    = {NBTI degradation: From physical mechanisms to modelling},
  year     = {2006},
  issn     = {0026-2714},
  number   = {1},
  pages    = {1-23},
  volume   = {46},
  abstract = {An overview of the evolution of transistor parameters under negative bias temperature instability stress conditions commonly observed in p-MOSFETs in recent technologies is presented. The physical mechanisms of the degradation as well as the different defects involved have been discussed according to a systematic set of experiments with different stress conditions. According to our findings, a physical model is proposed which could be used to more accurately predict the transistor degradation. Finally, based on our new present understanding, a new characterization methodology is proposed, which would open the way to a more accurate determination of parameter shifts and thus allowing implementing the degradation into design rules.},
  doi      = {https://doi.org/10.1016/j.microrel.2005.02.001},
  url      = {https://www.sciencedirect.com/science/article/pii/S0026271405000351},
}

@Article{nbti_recovery_2020,
  author   = {Boualem Djezzar and Abdelmadjid Benabdelmoumene and Boumediene Zatout and Dhiaelhak Messaoud and Amel Chenouf and Hakim Tahi and Mohamed Boubaaya and Hakima Timlelt},
  journal  = {Microelectronics Reliability},
  title    = {Recovery investigation of NBTI-induced traps in n-MOSFET devices},
  year     = {2020},
  issn     = {0026-2714},
  pages    = {113703},
  volume   = {110},
  abstract = {Conducting negative bias temperature instability (NBTI) stress/recovery experiments on n-type metal-oxide-semiconductor-field-effect-transistors (n-MOSFETs), we have been able to reveal the existence of turn around phenomenon during stress phase. At first stage of stress, threshold voltage (Vth) shifts positively, followed later by a negative shift. Furthermore, recovery phase has shown, for the first time, the contribution of three components to Vth shift (ΔVth) in n-MOSFET. One component is permanent (ΔVthP) and dominated by interface traps, created during stress at the Si/SiO2 interface. The other components are oxide traps, generated in the interfacial oxide region. Both traps are positively charged; one is cyclic (ΔVthC), while the other is totally recoverable (ΔVthR).},
  doi      = {https://doi.org/10.1016/j.microrel.2020.113703},
  keywords = {NBTI, n-MOSFET, Turn around phenomenon, Permanent component, Cyclic component, Recoverable component},
  ranking  = {rank4},
  url      = {https://www.sciencedirect.com/science/article/pii/S0026271420300482},
}

